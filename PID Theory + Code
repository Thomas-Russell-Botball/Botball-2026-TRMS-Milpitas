Final PID Code


void pidMove(float distance, float topSpeed,float finalError){
    cmpc(0); cmpc(1); cmpc(2); cmpc(3);
    float KP = 1.0;   //still need to be tuned
    float KI = 0.1;   //still need to be tuned
    float KD = 0.05;  //still need to be tuned

    //initialization
    float error = distance;
    float lastError = distance;
    float integral = 0;
    float dt =20;

        while(fabsf(error)>finalError){
            //1. Get input
            float position = (gmpc(0)+gmpc(1)+gmpc(2)+gmpc(3))/4;
            position*=(27/2000);
            
            //2. Calculate error
            error = distance - position;
            
            //3. Calculate terms
            integral = integral + (error * dt);
            derivative = (error - lastError) / dt;
            
            //4. Calculate output
            float output = (KP * error) + (KI * integral) - (KD * derivative);

            //Makes sure speed isn't over top speed
            if(output>topSpeed){
            output = topSpeed;        
            }
            
            //5. Apply output and save state  
            mav(0,output);
            mav(1,output);
            mav(3,output);
            mav(4,output);
            float lastError = error;
            
            //6. Wait for next time step
            msleep(dt);

        }
    freeze(0);
    freeze(1);
    freeze(2);
    freeze(3);

}
