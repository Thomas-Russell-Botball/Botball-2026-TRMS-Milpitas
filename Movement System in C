Instead of using
motor(RIGHTMOTOR, 50);
motor(LEFTMOTOER, 50);
msleep(500);

use
#include <std.lib>
#define LEFTMOTOR
#define RIGHTMOTOR

void drive(int distance, int speed){
  cmpc(RIGHTMOTOR);
  while(abs(gmpc(RIGHTMOTOR)) < distance){
    mav(RIGHTMOTOR, speed);
    mav(LEFTMOTOR, speed);
  }
  mav(RIGHTMOTOR, 0);
  mav(LEFTMOTOR, 0);
  msleep(20);
}


Now for turn
Instead of using
motor(RIGHTMOTOR, 50);
motor(LEFTMOTOR, -50);
msleep(500);

use
void turnright(int distance, int speed){
  cmpc(LEFTMOTOR);
  while(gmpc(LEFTMOTOR) < distance){
    mav(RIGHTMOTOR, -speed);
    mav(LEFTMOTOR, speed);
  }
  mav(RIGHTMOTOR, 0);
  mav(LEFTMOTOR, 0);
  msleep(20);
}

and


void turnleft(int distance, int speed){
  cmpc(RIGHTMOTOR);
  while(gmpc(RIGHTMOTOR) < distance){
    mav(RIGHTMOTOR, speed);
    mav(LEFTMOTOR, -speed);
  }
  mav(RIGHTMOTOR, 0);
  mav(LEFTMOTOR, 0);
  msleep(20);
}


mav is move at velocity so it will move at the same speed no matter the battery of the motor
gmpc gets motor position in ticks which can be translated to distance, 
so you can edit the speed of the mav without the distance changing
cmpc clears the motor position so it goes how much you want it to go
finally the thing at the end is to make sure it doesn't drift to a stop
